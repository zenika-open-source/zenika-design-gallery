---
import MainLayout from '../layouts/MainLayout.astro';
import VisualCard from '../components/VisualCard.astro';
import Lightbox from '../components/Lightbox.astro';
import visuals from '../data/visuals.json';
---

<MainLayout title="Accueil">
	<section class="container section-padding">
		<div class="hero">
			<h1><span class="text-red">Design</span> Gallery</h1>
			<p class="subtitle">Une rétrospective des visuels créés pour les conférences et événements Zenika.</p>
		</div>

		<div class="gallery-grid">
			{visuals.map((visual) => (
				<VisualCard 
					title={visual.title}
					occasion={visual.occasion}
					year={visual.year}
					image={visual.image}
				/>
			))}
		</div>
	</section>
	<Lightbox />
</MainLayout>

<style>
	.hero {
		text-align: center;
		margin-bottom: var(--spacing-xl);
	}

	h1 {
		font-size: 4rem;
		margin-bottom: var(--spacing-sm);
	}

	.subtitle {
		font-size: 1.25rem;
		max-width: 600px;
		margin: 0 auto;
		opacity: 0.7;
		font-weight: 300;
	}

	@media (max-width: 768px) {
		h1 {
			font-size: 2.5rem;
		}
	}
</style>
