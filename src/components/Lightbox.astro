---
---

<dialog id="lightbox-dialog" class="lightbox">
	<div class="lightbox-content">
		<button id="close-lightbox" class="close-btn" aria-label="Fermer">
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
		</button>
		<button id="prev-lightbox" class="nav-btn prev-btn" aria-label="Précédent">
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
		</button>
		<button id="next-lightbox" class="nav-btn next-btn" aria-label="Suivant">
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
		</button>
		<img id="lightbox-img" src="" alt="" />
		<video id="lightbox-video" src="" controls autoplay loop playsinline style="display: none;"></video>
		<div class="lightbox-info">
			<h2 id="lightbox-title"></h2>
			<p id="lightbox-description"></p>
		</div>
	</div>
</dialog>

<script>
	function setupLightbox() {
		const dialog = document.getElementById('lightbox-dialog') as HTMLDialogElement;
		const closeBtn = document.getElementById('close-lightbox');
		const prevBtn = document.getElementById('prev-lightbox');
		const nextBtn = document.getElementById('next-lightbox');
		const img = document.getElementById('lightbox-img') as HTMLImageElement;
		const video = document.getElementById('lightbox-video') as HTMLVideoElement;
		const title = document.getElementById('lightbox-title');
		const description = document.getElementById('lightbox-description');
		const cards = Array.from(document.querySelectorAll('[data-lightbox]')) as HTMLElement[];
		let currentIndex = 0;

		function getVisibleCards() {
			return Array.from(document.querySelectorAll('[data-lightbox]:not(.hidden)')) as HTMLElement[];
		}

		function showCard(index: number) {
			const visibleCards = getVisibleCards();
			if (visibleCards.length === 0) return;
			
			if (index < 0) index = visibleCards.length - 1;
			if (index >= visibleCards.length) index = 0;
			currentIndex = index;
			
			const card = visibleCards[currentIndex];
			if (!card) return;

			const { image, video: vidSrc, title: text, occasion } = card.dataset;
			if (title && description) {
				if (vidSrc) {
					img.style.display = 'none';
					video.style.display = 'block';
					video.src = vidSrc;
				} else {
					video.style.display = 'none';
					video.pause();
					img.style.display = 'block';
					img.src = image || '';
					img.alt = text || '';
				}
				title.textContent = text || '';
				description.textContent = occasion || '';
			}
		}

		cards.forEach((card) => {
			card.addEventListener('click', () => {
				const visibleCards = getVisibleCards();
				const index = visibleCards.indexOf(card);
				if (index !== -1) {
					showCard(index);
					dialog?.showModal();
				}
			});
		});

		closeBtn?.addEventListener('click', () => {
			video?.pause();
			dialog?.close();
		});

		prevBtn?.addEventListener('click', (e) => {
			e.stopPropagation();
			showCard(currentIndex - 1);
		});

		nextBtn?.addEventListener('click', (e) => {
			e.stopPropagation();
			showCard(currentIndex + 1);
		});

		document.addEventListener('keydown', (e) => {
			if (!dialog?.open) return;
			if (e.key === 'ArrowLeft') showCard(currentIndex - 1);
			if (e.key === 'ArrowRight') showCard(currentIndex + 1);
		});

		// Close on click outside
		dialog?.addEventListener('click', (e) => {
			const dialogDimensions = dialog.getBoundingClientRect();
			if (
				e.clientX < dialogDimensions.left ||
				e.clientX > dialogDimensions.right ||
				e.clientY < dialogDimensions.top ||
				e.clientY > dialogDimensions.bottom
			) {
				dialog.close();
			}
		});
	}

	// Setup on initial load
	setupLightbox();

	// Setup on view transitions
	document.addEventListener('astro:after-swap', setupLightbox);
</script>

<style>
	.lightbox {
		padding: 0;
		border: none;
		background: transparent;
		max-width: 90vw;
		max-height: 90vh;
		border-radius: var(--border-radius);
		overflow: hidden;
		margin: auto;
	}

	.lightbox::backdrop {
		background: rgba(0, 0, 0, 0.85);
		backdrop-filter: blur(8px);
	}

	.lightbox-content {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		background: var(--zenika-white);
		width: 100%;
		height: 100%;
		min-height: 200px;
	}

	.close-btn {
		position: absolute;
		top: var(--spacing-md);
		right: var(--spacing-md);
		background: var(--zenika-red);
		color: white;
		border: none;
		border-radius: 50%;
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		z-index: 10;
		transition: var(--transition-smooth);
		box-shadow: 0 4px 10px rgba(0,0,0,0.2);
	}

	.close-btn:hover {
		transform: rotate(90deg) scale(1.1);
	}

	.nav-btn {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		background: rgba(255, 255, 255, 0.8);
		color: var(--zenika-black);
		border: none;
		border-radius: 50%;
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		z-index: 10;
		transition: var(--transition-smooth);
		box-shadow: 0 4px 10px rgba(0,0,0,0.1);
	}

	.nav-btn:hover {
		background: var(--zenika-white);
		transform: translateY(-50%) scale(1.1);
	}

	.prev-btn {
		left: var(--spacing-md);
	}

	.next-btn {
		right: var(--spacing-md);
	}

	img, video {
		max-width: 100%;
		max-height: 75vh;
		width: auto;
		height: auto;
		display: block;
		object-fit: contain;
		background: #f0f0f0;
	}

	.lightbox-info {
		padding: var(--spacing-lg);
		text-align: center;
	}

	h2 {
		margin-bottom: var(--spacing-sm);
		font-size: 1.5rem;
		color: var(--zenika-black);
	}

	p {
		color: #666;
	}
</style>
