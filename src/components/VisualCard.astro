---
interface Props {
	title: string;
	occasion: string;
	year: number | string;
	image?: string;
	video?: string;
	type: string;
}

const { title, occasion, year, image, video, type } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
let fullPath = '';
let isVideo = type === 'video';
if (isVideo && video) {
	fullPath = video.startsWith('/') ? `${baseUrl}${video.slice(1)}` : `${baseUrl}${video}`;
} else if (image) {
	fullPath = image.startsWith('/') ? `${baseUrl}${image.slice(1)}` : `${baseUrl}${image}`;
}
---

<div class="card hover-lift visual-card" data-type={type} data-lightbox data-image={!isVideo ? fullPath : ''} data-video={isVideo ? fullPath : ''} data-title={title} data-occasion={occasion}>
	<div class="image-container">
		{isVideo ? (
			<video src={fullPath} autoplay loop muted playsinline></video>
		) : (
			<img src={fullPath} alt={title} loading="lazy" />
		)}
		<div class="year-badge">{year}</div>
	</div>
	<div class="content">
		<h3>{title}</h3>
		<p>{occasion}</p>
	</div>
</div>

<style>
	.card {
		background: var(--zenika-white);
		border-radius: var(--border-radius);
		overflow: hidden;
		display: flex;
		flex-direction: column;
		border: 1px solid var(--zenika-gray-light);
		cursor: pointer;
	}

	.image-container {
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background-color: var(--zenika-gray-light);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.image-container img, .image-container video {
		width: 100%;
		height: 100%;
		object-fit: contain;
		transition: var(--transition-smooth);
	}

	.card:hover .image-container img, .card:hover .image-container video {
		transform: scale(1.05);
	}

	.year-badge {
		position: absolute;
		top: var(--spacing-md);
		right: var(--spacing-md);
		background: var(--zenika-red);
		color: #FFFFFF;
		padding: 4px 12px;
		border-radius: 20px;
		font-weight: 700;
		font-size: 0.8rem;
		box-shadow: 0 4px 10px rgba(235, 68, 50, 0.3);
	}

	.content {
		padding: var(--spacing-lg);
	}

	h3 {
		margin-bottom: var(--spacing-sm);
		font-size: 1.25rem;
		color: var(--zenika-black);
	}

	p {
		font-size: 0.95rem;
		color: var(--text-muted);
		font-weight: 300;
	}
</style>
